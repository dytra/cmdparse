{
  "name": "cmdparse",
  "version": "1.0.1",
  "description": "A lightweight CLI-style command parser that converts raw input strings into structured command, arguments, and flags.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dytra/cmdparse"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "cli",
    "parser",
    "command",
    "args",
    "flags",
    "typescript",
    "utility"
  ],
  "author": "dytra",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  }
}